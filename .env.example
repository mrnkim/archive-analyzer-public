# TwelveLabs Jockey API
# Get a key from https://playground.twelvelabs.io
TWELVELABS_API_KEY=tlk_your_key_here

# Jockey API base URL (override only for staging/regional endpoints)
JOCKEY_BASE_URL=https://api.twelvelabs.io/v1.3

# Knowledge Store ID — fill in after ingesting your video corpus
# e.g. ks_abc123def456...
KS_ID=

# CORS — local Vite dev server; in production set to your Railway domain
ALLOWED_ORIGINS=http://localhost:5173

# Rate limiting (for public sample app)
# Max requests per minute per IP
RATE_LIMIT_PER_MINUTE=10

# Environment
APP_ENV=development
